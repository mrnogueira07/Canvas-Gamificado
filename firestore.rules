rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Coleção de projetos: usuário só acessa seus próprios projetos
    match /projects/{projectId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Coleção de usuários: cada usuário acessa apenas seu perfil
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Coleção de pastas: usuário só acessa suas próprias pastas
    match /folders/{folderId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
  }
}
